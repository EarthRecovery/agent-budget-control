[36m(TaskRunner pid=3821232)[0m                                                     '\n'
[36m(TaskRunner pid=3821232)[0m                                                     'The rules of the '
[36m(TaskRunner pid=3821232)[0m                                                     'environment are as '
[36m(TaskRunner pid=3821232)[0m                                                     'follows:\n'
